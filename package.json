{
  "name": "college-events-fullstack",
  "version": "1.0.0",
  "description": "Full-stack College Events Management System",
  "scripts": {
    "install-all": "cd backend && npm install && cd ../frontend && npm install",
    "start-backend": "cd backend && node server.js",
    "start-frontend": "cd frontend && npx live-server --port=3001 --host=localhost",
    "dev-backend": "cd backend && node server.js",
    "dev": "concurrently \"npm run start-backend\" \"npm run start-frontend\"",
    "setup": "npm run install-all && echo 'Setup complete! Run npm run dev to start both servers'"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "live-server": "^1.2.2"
  },
  "author": "",
  "license": "ISC"
}